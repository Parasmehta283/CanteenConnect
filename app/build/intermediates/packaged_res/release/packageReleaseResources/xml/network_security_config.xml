<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production configuration - only trust system certificates -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust only preinstalled CAs -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
